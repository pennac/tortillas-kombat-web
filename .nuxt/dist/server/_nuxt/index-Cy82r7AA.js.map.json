OAAO,KAAK,EAAE,KAAK,CAAC,GAAG,MAAM;AAC9C,eAAO,IAAI,KAAK,EAAE,WAAW,EAAE,YAAY,IAAI,KAAK,EAAE,WAAW,EAAE,QAAA;AAAA,MACrE,CAAC;AAED,YAAM,WAAkB,CAAA;AACxB,UAAI,kBAAkB;AAEtB,iBAAW,SAAS,QAAQ;AAC1B,cAAM,cAAc,IAAI,KAAK,MAAM,WAAW;AAC9C,oBAAY,SAAS,GAAE,GAAE,GAAE,CAAC;AAE5B,YAAI,WAAW,aAAa;AAC1B,mBAAS,KAAK,KAAK;AAAA,QACrB,WAAW,CAAC,iBAAiB;AAE3B,mBAAS,KAAK,KAAK;AACnB,4BAAkB;AAAA,QACpB;AAAA,MACF;AAEA,aAAO;AAAA,IACT,CAAC;;;mBAjEMP,eAAAC,WAAA,EAAA,OAAM,qDAAiD,MAAA,CAAA,4HACuC,EAAA,eAAA,mCAAA,CAAsD;UAG5IO,MAAA,OAAA,GAAO;;iBAGFA,MAAA,KAAA,GAAK;;;;AAKDC,sBAAA,gBAAA,QAAT,UAAK;AAEX,gBAAA,OAAAL,cAAA,MAAI,MAAM,OAAO,WAAW,IAAA,KAAG,EAAA,CAAA,GAAA;;YAG7B,OAAO,MAAM;AAAA,YACb,aAAa,MAAM,eAAW;AAAA,YAC9B,OAAO,MAAM;AAAA,YACb,MAAM,MAAM,SAAK;AAAA,YACjB,aAAa,MAAM;AAAA,UAAA;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_push","_parent","_ssrRenderAttr","_createVNode","_createBlock","_withAsyncContext","_unref","_ssrRenderList"],"sources":["../../../../components/ChapterCard.vue","../../../../pages/comics/index.vue"],"sourcesContent":["<template>\n  <div class=\"relative w-full border-2 border-zinc-900 bg-white overflow-hidden group shadow-[4px_4px_0_rgba(24,24,27,1)] transition-transform hover:-translate-y-1\">\n    <!-- Unlocked visual -->\n    <NuxtLink v-if=\"isUnlocked\" :to=\"link\" class=\"block w-full h-full text-left\">\n      <div class=\"relative h-78 w-full overflow-hidden flex items-center justify-center bg-zinc-50 border-b-2 border-zinc-900\">\n        <video \n          v-if=\"cover && cover.toLowerCase().endsWith('.mp4')\" \n          :src=\"cover\" \n          autoplay loop muted playsinline \n          class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\"\n        ></video>\n        <img \n          v-else \n          :src=\"cover\" \n          :alt=\"title\" \n          class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" \n        />\n        <div class=\"absolute inset-0 bg-gradient-to-t from-white via-white/10 to-transparent\"></div>\n      </div>\n      <div class=\"p-4 relative z-10 bg-white\">\n        <h3 class=\"font-header font-bold text-xl text-zinc-900 mb-1 group-hover:text-amber-800 transition-colors\">{{ title }}</h3>\n        <p class=\"font-body text-sm text-zinc-700 line-clamp-2 mb-4\">{{ description }}</p>\n        <span class=\"inline-block border-2 border-zinc-900 text-zinc-900 px-3 py-1 font-header font-bold text-xs group-hover:bg-zinc-100 transition-colors\">\n          Leer Capítulo\n        </span>\n      </div>\n    </NuxtLink>\n\n    <!-- Locked visual -->\n    <div v-else class=\"block w-full h-full grayscale opacity-80 pointer-events-none cursor-not-allowed\">\n      <div class=\"relative h-78 w-full overflow-hidden flex items-center justify-center bg-zinc-100 border-b-2 border-zinc-900\">\n        <video \n          v-if=\"cover && cover.toLowerCase().endsWith('.mp4')\" \n          :src=\"cover\" \n          autoplay loop muted playsinline \n          class=\"w-full h-full object-cover opacity-60\"\n        ></video>\n        <img \n          v-else \n          :src=\"cover\" \n          :alt=\"title\" \n          class=\"w-full h-full object-cover opacity-60\" \n        />\n        <div class=\"absolute inset-0 bg-white/40 flex flex-col items-center justify-center\">\n            <span class=\"text-4xl mb-2 drop-shadow-md\">🔒</span>\n            <span class=\"font-header font-bold text-xs text-zinc-900 bg-white border-2 border-zinc-900 px-3 py-1 text-center shadow-[2px_2px_0_rgba(24,24,27,1)]\">\n              Sellado hasta:<br/>{{ formattedDate }}\n            </span>\n        </div>\n      </div>\n      <div class=\"p-4 relative z-10 bg-zinc-50\">\n        <h3 class=\"font-header font-bold text-xl text-zinc-600 mb-1\">{{ title }}</h3>\n        <p class=\"font-body text-sm text-zinc-500 line-clamp-2\">{{ description }}</p>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed } from 'vue'\n\nconst props = defineProps<{\n  title: string\n  description: string\n  cover: string\n  link: string\n  releaseDate: string\n}>()\n\nconst isUnlocked = computed(() => {\n  const current = new Date()\n  const release = new Date(props.releaseDate)\n  current.setHours(0,0,0,0)\n  release.setHours(0,0,0,0)\n  return current >= release\n})\n\nconst formattedDate = computed(() => {\n  if (!props.releaseDate) return 'Desconocida'\n  const parts = props.releaseDate.split('-')\n  if (parts.length === 3) {\n    return `${parts[2]}/${parts[1]}/${parts[0]}`\n  }\n  return props.releaseDate\n})\n</script>\n","<template>\n  <div class=\"w-full relative min-h-screen bg-white px-4 py-8\">\n    <h1 class=\"font-header font-black text-4xl text-zinc-900 text-center mb-2 mt-4 tracking-tighter\" style=\"text-shadow: 2px 2px 0 #fff, -1px -1px 0 #fff;\">LOS CAPÍTULOS</h1>\n    <p class=\"font-body font-bold text-center text-zinc-600 text-xs mb-8 uppercase tracking-widest\">Archivio della Resistenza</p>\n\n    <div v-if=\"pending\" class=\"text-center font-body font-bold text-amber-600\">\n      Cargando...\n    </div>\n    <div v-else-if=\"error\" class=\"text-center font-body font-bold text-red-600\">\n      Error al cargar los capítulos.\n    </div>\n    <div v-else class=\"grid grid-cols-1 gap-6\">\n      <div \n        v-for=\"comic in displayedComics\" \n        :key=\"comic._path\"\n        :id=\"comic._path?.split('/').pop() || ''\"\n      >\n        <ChapterCard \n          :title=\"comic.title\"\n          :description=\"comic.description || 'Sin descripción.'\"\n          :cover=\"comic.cover\"\n          :link=\"comic._path || '/'\"\n          :releaseDate=\"comic.releaseDate\"\n        />\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed } from 'vue'\n\nuseHead({ title: 'Capítulos - Tortillas Kombat' })\n\nconst { data: comics, pending, error } = await useAsyncData('comics-archive', () => \n  queryContent('/comics').sort({ title: 1 }).find()\n)\n\nconst displayedComics = computed(() => {\n  if (!comics.value) return []\n  \n  const current = new Date()\n  current.setHours(0,0,0,0)\n\n  // Sort chronologically by releaseDate just in case\n  const sorted = [...comics.value].sort((a, b) => {\n    return new Date(a.releaseDate).getTime() - new Date(b.releaseDate).getTime()\n  })\n\n  const released: any[] = []\n  let unreleasedAdded = false\n\n  for (const comic of sorted) {\n    const releaseDate = new Date(comic.releaseDate)\n    releaseDate.setHours(0,0,0,0)\n\n    if (current >= releaseDate) {\n      released.push(comic)\n    } else if (!unreleasedAdded) {\n      // Add exactly one unreleased future chapter\n      released.push(comic)\n      unreleasedAdded = true\n    }\n  }\n\n  return released\n})\n</script>\n"],"version":3}