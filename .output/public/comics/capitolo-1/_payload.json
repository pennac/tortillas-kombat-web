[{"data":1,"prerenderedAt":65},["ShallowReactive",2],{"comic-capitolo-1":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"cover":10,"releaseDate":11,"audioTheme":12,"panels":13,"_id":60,"_type":61,"_source":62,"_file":63,"_stem":64,"_extension":61},"/comics/capitolo-1","comics",false,"","01: El Vapor de Sartenópolis","En las calles oxidadas de la capital, el vapor oculta la miseria. Un ronin solitario llega a la ciudad buscando algo más que comida sintética.","../capitoli/capitulo1/VCover.mp4","2023-01-01","../audio/TKILTRAILERHYPE.mp3",[14,17,20,23,26,30,33,36,39,42,46,50,54,57],{"type":15,"src":16,"textOverlay":9,"textEffect":7},"Video","../capitoli/capitulo1/Vcover.mp4",{"type":15,"src":18,"textOverlay":19,"textEffect":7},"../capitoli/capitulo1/V01.mp4","Era del Colesterol, Año 20XX. Sartenópolis: Donde el aceite nunca deja de hervir.",{"type":15,"src":21,"textOverlay":22,"textEffect":7},"../capitoli/capitulo1/V02.mp4","PATATAS REGENERADAS - OFERTA! En las calles, los ''impuros'' se arrastran por una gota de salsa.",{"type":15,"src":24,"textOverlay":25,"textEffect":7},"../capitoli/capitulo1/V03.mp4","¡LA PUREZA ES ORDEN. EL ORDEN ES SABOR. El Ojo del Tuorlo lo ve todo.",{"type":15,"src":27,"textOverlay":28,"textEffect":29},"../capitoli/capitulo1/V04.mp4","La Guardia avanza. Sin preguntas. Sin piedad.","CLANK! CLANK!",{"type":15,"src":31,"textOverlay":32,"textEffect":7},"../capitoli/capitulo1/V05.mp4","DOCUMENTACIÓN! ¡AHORA! El miedo tiene sabor metálico.",{"type":15,"src":34,"textOverlay":35,"textEffect":7},"../capitoli/capitulo1/V06.mp4","¡GERMINACIÓN ILEGAL DETECTADA! Ser diferente es sentencia de muerte.",{"type":15,"src":37,"textOverlay":38,"textEffect":7},"../capitoli/capitulo1/V07.mp4","Pero el vapor oculta secretos. Un guerrero cocinado a fuego lento.",{"type":15,"src":40,"textOverlay":41,"textEffect":7},"../capitoli/capitulo1/V08.mp4","Ojos que han visto caer imperios.",{"type":15,"src":43,"textOverlay":44,"textEffect":45},"../capitoli/capitulo1/V09.mp4","Una sombra pequeña y rápida rompe el miedo.","¡ZAS!",{"type":15,"src":47,"textOverlay":48,"textEffect":49},"../capitoli/capitulo1/V10.mp4","¡LADRONA! ¡DETENGAN A LA ACEITUNA!","WEEE-OOO-WEEE-OOO",{"type":15,"src":51,"textOverlay":52,"textEffect":53},"../capitoli/capitulo1/V11.mp4","Se acabó el descanso.","K-CLACK",{"type":15,"src":55,"textOverlay":56,"textEffect":7},"../capitoli/capitulo1/V12.mp4","Oye, Huevo... te vas a quemar.",{"type":15,"src":58,"textOverlay":59,"textEffect":7},"../capitoli/capitulo1/V13.mp4","El Ronin entra en la cocina.","content:comics:capitolo-1.json","json","content","comics/capitolo-1.json","comics/capitolo-1",1771727123801]