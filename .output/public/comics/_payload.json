[{"data":1,"prerenderedAt":313},["ShallowReactive",2],{"comics-archive":3},[4,66,80,92,103,114,127,138,149,160,171,182,193,204,215,226,236,247,258,269,280,291,302],{"_path":5,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":9,"description":10,"cover":11,"releaseDate":12,"audioTheme":13,"panels":14,"_id":61,"_type":62,"_source":63,"_file":64,"_stem":65,"_extension":62},"/comics/capitolo-1","comics",false,"","01: El Vapor de Sartenópolis","En las calles oxidadas de la capital, el vapor oculta la miseria. Un ronin solitario llega a la ciudad buscando algo más que comida sintética.","../capitoli/capitulo1/VCover.mp4","2023-01-01","../audio/TKILTRAILERHYPE.mp3",[15,18,21,24,27,31,34,37,40,43,47,51,55,58],{"type":16,"src":17,"textOverlay":10,"textEffect":8},"Video","../capitoli/capitulo1/Vcover.mp4",{"type":16,"src":19,"textOverlay":20,"textEffect":8},"../capitoli/capitulo1/V01.mp4","Era del Colesterol, Año 20XX. Sartenópolis: Donde el aceite nunca deja de hervir.",{"type":16,"src":22,"textOverlay":23,"textEffect":8},"../capitoli/capitulo1/V02.mp4","PATATAS REGENERADAS - OFERTA! En las calles, los ''impuros'' se arrastran por una gota de salsa.",{"type":16,"src":25,"textOverlay":26,"textEffect":8},"../capitoli/capitulo1/V03.mp4","¡LA PUREZA ES ORDEN. EL ORDEN ES SABOR. El Ojo del Tuorlo lo ve todo.",{"type":16,"src":28,"textOverlay":29,"textEffect":30},"../capitoli/capitulo1/V04.mp4","La Guardia avanza. Sin preguntas. Sin piedad.","CLANK! CLANK!",{"type":16,"src":32,"textOverlay":33,"textEffect":8},"../capitoli/capitulo1/V05.mp4","DOCUMENTACIÓN! ¡AHORA! El miedo tiene sabor metálico.",{"type":16,"src":35,"textOverlay":36,"textEffect":8},"../capitoli/capitulo1/V06.mp4","¡GERMINACIÓN ILEGAL DETECTADA! Ser diferente es sentencia de muerte.",{"type":16,"src":38,"textOverlay":39,"textEffect":8},"../capitoli/capitulo1/V07.mp4","Pero el vapor oculta secretos. Un guerrero cocinado a fuego lento.",{"type":16,"src":41,"textOverlay":42,"textEffect":8},"../capitoli/capitulo1/V08.mp4","Ojos que han visto caer imperios.",{"type":16,"src":44,"textOverlay":45,"textEffect":46},"../capitoli/capitulo1/V09.mp4","Una sombra pequeña y rápida rompe el miedo.","¡ZAS!",{"type":16,"src":48,"textOverlay":49,"textEffect":50},"../capitoli/capitulo1/V10.mp4","¡LADRONA! ¡DETENGAN A LA ACEITUNA!","WEEE-OOO-WEEE-OOO",{"type":16,"src":52,"textOverlay":53,"textEffect":54},"../capitoli/capitulo1/V11.mp4","Se acabó el descanso.","K-CLACK",{"type":16,"src":56,"textOverlay":57,"textEffect":8},"../capitoli/capitulo1/V12.mp4","Oye, Huevo... te vas a quemar.",{"type":16,"src":59,"textOverlay":60,"textEffect":8},"../capitoli/capitulo1/V13.mp4","El Ronin entra en la cocina.","content:comics:capitolo-1.json","json","content","comics/capitolo-1.json","comics/capitolo-1",{"_path":67,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":68,"description":69,"cover":70,"releaseDate":71,"audioTheme":13,"panels":72,"_id":77,"_type":62,"_source":63,"_file":78,"_stem":79,"_extension":62},"/comics/capitolo-2","02: El Robo de la Aceituna","Una pequeña ladrona corre por los tejados. Cuando la ley del más fuerte está a punto de aplastarla, un cucharón de madera cambia su destino.","../capitoli/capitulo2/VCover.mp4","2025-03-21",[73,75],{"type":16,"src":74,"textOverlay":8,"textEffect":8},"../capitoli/capitulo2/V01.mp4",{"type":16,"src":76,"textOverlay":8,"textEffect":8},"../capitoli/capitulo2/V02.mp4","content:comics:capitolo-2.json","comics/capitolo-2.json","comics/capitolo-2",{"_path":81,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":82,"description":83,"cover":84,"releaseDate":85,"audioTheme":13,"panels":86,"_id":89,"_type":62,"_source":63,"_file":90,"_stem":91,"_extension":62},"/comics/capitolo-3","03: El Banquete de los Pobres","Un convoy militar lleno de verduras reales es interceptado. Esa noche, el barrio bajo conoce el verdadero sabor, pero el cielo trae una advertencia digital.","../capitoli/capitulo3/VCover.mp4","2026-04-21",[87,88],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-3.json","comics/capitolo-3.json","comics/capitolo-3",{"_path":93,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":94,"description":95,"cover":96,"releaseDate":85,"audioTheme":13,"panels":97,"_id":100,"_type":62,"_source":63,"_file":101,"_stem":102,"_extension":62},"/comics/capitolo-4","04: Cenizas y Recuerdos","Huyendo al desierto blanco, bajo la luz de las estrellas, Patato revela la cicatriz de su pasado: la historia de dos hermanos en la Academia del Vuelco.","../capitoli/capitulo4/VCover.mp4",[98,99],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-4.json","comics/capitolo-4.json","comics/capitolo-4",{"_path":104,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":105,"description":106,"cover":107,"releaseDate":85,"audioTheme":13,"panels":108,"_id":111,"_type":62,"_source":63,"_file":112,"_stem":113,"_extension":62},"/comics/capitolo-5","05: El Fruto Prohibido","En el mercado negro, el Joven Patato prueba lo impensable: la cebolla. Una explosión de sabor que cambiará su vida para siempre.","../capitoli/capitulo5/VCover.mp4",[109,110],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-5.json","comics/capitolo-5.json","comics/capitolo-5",{"_path":115,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":116,"description":117,"cover":118,"releaseDate":119,"audioTheme":13,"panels":120,"_id":124,"_type":62,"_source":63,"_file":125,"_stem":126,"_extension":62},"/comics/capitolo-6","06: La Traición Mecánica","El amanecer trae la acusación. Roto denuncia a su hermano por impureza. Un juicio farsa, un uniforme rasgado y el exilio al desierto.","../capitoli/capitulo6/VCover.mp4","2027-04-21",[121,123],{"type":16,"src":122,"textOverlay":8,"textEffect":8},"../capitoli/capitulo6/V01.mp4",{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-6.json","comics/capitolo-6.json","comics/capitolo-6",{"_path":128,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":129,"description":130,"cover":131,"releaseDate":119,"audioTheme":13,"panels":132,"_id":135,"_type":62,"_source":63,"_file":136,"_stem":137,"_extension":62},"/comics/capitolo-7","07: El Santuario de Sal","De vuelta al presente. En las Minas de Sal, Patato debe endurecer su piel para soportar el peso del mundo. La primera lección es la consistencia.","../capitoli/capitulo7/VCover.mp4",[133,134],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-7.json","comics/capitolo-7.json","comics/capitolo-7",{"_path":139,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":140,"description":141,"cover":142,"releaseDate":119,"audioTheme":13,"panels":143,"_id":146,"_type":62,"_source":63,"_file":147,"_stem":148,"_extension":62},"/comics/capitolo-8","08: El Desierto de Pimentón","Un infierno rojo de polvo y calor. El Barón del Chorizo enseña que la mejor defensa es un ataque ardiente. Patato despierta su fuego interior.","../capitoli/capitulo8/VCover.mp4",[144,145],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-8.json","comics/capitolo-8.json","comics/capitolo-8",{"_path":150,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":151,"description":152,"cover":153,"releaseDate":119,"audioTheme":13,"panels":154,"_id":157,"_type":62,"_source":63,"_file":158,"_stem":159,"_extension":62},"/comics/capitolo-9","09: El Bosque Apestoso","Una ciénaga verde y tóxica. La Abuela Ajo demuestra que el verdadero poder es la persistencia: un aroma que nunca se va.","../capitoli/capitulo9/VCover.mp4",[155,156],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-9.json","comics/capitolo-9.json","comics/capitolo-9",{"_path":161,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":162,"description":163,"cover":164,"releaseDate":119,"audioTheme":13,"panels":165,"_id":168,"_type":62,"_source":63,"_file":169,"_stem":170,"_extension":62},"/comics/capitolo-10","10: El Monje del Aceite","En un templo flotante sobre un río negro, la fuerza bruta resbala. Patato debe aprender a fluir y emulsionarse con el enemigo.","../capitoli/capitulo10/VCover.mp4",[166,167],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-10.json","comics/capitolo-10.json","comics/capitolo-10",{"_path":172,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":173,"description":174,"cover":175,"releaseDate":119,"audioTheme":13,"panels":176,"_id":179,"_type":62,"_source":63,"_file":180,"_stem":181,"_extension":62},"/comics/capitolo-11","11: El Laberinto de Pimientos","Una jungla donde la lógica no existe. Los gemelos del azar juegan con la mente de Patato. La lección es la sorpresa: lo dulce y lo picante a la vez.","../capitoli/capitulo11/VCover.mp4",[177,178],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-11.json","comics/capitolo-11.json","comics/capitolo-11",{"_path":183,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":184,"description":185,"cover":186,"releaseDate":119,"audioTheme":13,"panels":187,"_id":190,"_type":62,"_source":63,"_file":191,"_stem":192,"_extension":62},"/comics/capitolo-12","12: El Espíritu del Pan","Entre ruinas antiguas, un gigante de miga enseña que nadie puede sostenerse solo. Aceituna se convierte en el pilar fundamental de Patato.","../capitoli/capitulo12/VCover.mp4",[188,189],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-12.json","comics/capitolo-12.json","comics/capitolo-12",{"_path":194,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":195,"description":196,"cover":197,"releaseDate":119,"audioTheme":13,"panels":198,"_id":201,"_type":62,"_source":63,"_file":202,"_stem":203,"_extension":62},"/comics/capitolo-13","13: Las Alcantarillas de la Resistencia","En el subsuelo, la Matriarca Cebolla espera. Para obtener el último sello, Patato debe llorar y romper su coraza emocional. La Armonía final.","../capitoli/capitulo13/VCover.mp4",[199,200],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-13.json","comics/capitolo-13.json","comics/capitolo-13",{"_path":205,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":206,"description":207,"cover":208,"releaseDate":119,"audioTheme":13,"panels":209,"_id":212,"_type":62,"_source":63,"_file":213,"_stem":214,"_extension":62},"/comics/capitolo-14","14: La Prisión de la Despensa","Infiltración fallida en Sartenópolis. Patato es capturado y congelado. Aceituna y una vieja amiga ninja lanzan un rescate desesperado.","../capitoli/capitulo14/VCover.mp4",[210,211],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-14.json","comics/capitolo-14.json","comics/capitolo-14",{"_path":216,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":217,"description":218,"cover":219,"releaseDate":119,"audioTheme":13,"panels":220,"_id":223,"_type":62,"_source":63,"_file":224,"_stem":225,"_extension":62},"/comics/capitolo-15","15: El Sacrificio del Maestro","En la arena, la burocracia amenaza con descalificar al Ronin. Un viejo maestro entrega su honor y su vida para darle una oportunidad a su alumno.","../capitoli/capitulo15/VCover.mp4",[221,222],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-15.json","comics/capitolo-15.json","comics/capitolo-15",{"_path":227,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":228,"description":229,"cover":107,"releaseDate":119,"audioTheme":13,"panels":230,"_id":233,"_type":62,"_source":63,"_file":234,"_stem":235,"_extension":62},"/comics/capitolo-16","16: La Sartén Vacía","Sin ingredientes, confiscados por el régimen. Patato-Pan está solo. Aceituna le lanza su herencia: una única anchoa que vale por un ejército.",[231,232],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-16.json","comics/capitolo-16.json","comics/capitolo-16",{"_path":237,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":238,"description":239,"cover":240,"releaseDate":119,"audioTheme":13,"panels":241,"_id":244,"_type":62,"_source":63,"_file":245,"_stem":246,"_extension":62},"/comics/capitolo-17","17: La Ofrenda del Pueblo - Cuartos de Final","Contra un robot ultra-rápido. El pueblo se rebela lanzando comida a la arena. Patato cocina el caos y vence a la lógica de la máquina.","../capitoli/capitulo17/VCover.mp4",[242,243],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-17.json","comics/capitolo-17.json","comics/capitolo-17",{"_path":248,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":249,"description":250,"cover":251,"releaseDate":119,"audioTheme":13,"panels":252,"_id":255,"_type":62,"_source":63,"_file":256,"_stem":257,"_extension":62},"/comics/capitolo-18","18: La Semifinal Brutal","Contra la fuerza pura. Un culturista de cáscara impenetrable. Patato usa el aceite para hacer caer al gigante por su propio peso.","../capitoli/capitulo18/VCover.mp4",[253,254],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-18.json","comics/capitolo-18.json","comics/capitolo-18",{"_path":259,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":260,"description":261,"cover":262,"releaseDate":119,"audioTheme":13,"panels":263,"_id":266,"_type":62,"_source":63,"_file":267,"_stem":268,"_extension":62},"/comics/capitolo-19","19: Alma contra Máquina (La Gran Final - Parte 1)","Patato-Pan vs Roto. Madera vs Oro. Mientras cocinan y luchan, Roto confiesa su envidia: la técnica nunca pudo superar al talento natural.","../capitoli/capitulo19/VCover.mp4",[264,265],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-19.json","comics/capitolo-19.json","comics/capitolo-19",{"_path":270,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":271,"description":272,"cover":273,"releaseDate":119,"audioTheme":13,"panels":274,"_id":277,"_type":62,"_source":63,"_file":278,"_stem":279,"_extension":62},"/comics/capitolo-20","20: El Juicio del Gusto (La Gran Final - Parte 2)","Los platos se sirven. Roto llora al probar el sabor de la infancia. Frito, furioso por la derrota ideológica, activa su Trono de Guerra.","../capitoli/capitulo20/VCover.mp4",[275,276],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-20.json","comics/capitolo-20.json","comics/capitolo-20",{"_path":281,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":282,"description":283,"cover":284,"releaseDate":119,"audioTheme":13,"panels":285,"_id":288,"_type":62,"_source":63,"_file":289,"_stem":290,"_extension":62},"/comics/capitolo-21","21: El Asedio del Cascarón","El Mecha-Trono destruye la arena. Patato y Roto luchan juntos. Roto sacrifica su espátula de oro para bloquear los engranajes del monstruo.","../capitoli/capitulo21/VCover.mp4",[286,287],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-21.json","comics/capitolo-21.json","comics/capitolo-21",{"_path":292,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":293,"description":294,"cover":295,"releaseDate":119,"audioTheme":13,"panels":296,"_id":299,"_type":62,"_source":63,"_file":300,"_stem":301,"_extension":62},"/comics/capitolo-22","22: La Gran Tortilla","La explosión final. Una onda expansiva de huevo cubre la ciudad. El tirano emerge desnudo y ridículo, derrotado por la risa del pueblo.","../capitoli/capitulo22/VCover.mp4",[297,298],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-22.json","comics/capitolo-22.json","comics/capitolo-22",{"_path":303,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":304,"description":305,"cover":306,"releaseDate":119,"audioTheme":13,"panels":307,"_id":310,"_type":62,"_source":63,"_file":311,"_stem":312,"_extension":62},"/comics/capitolo-23","23: El Gran Banquete (Epílogo)","Un año después. Sartenópolis es verde y libre. Una mesa larga reúne a amigos y antiguos enemigos. La guerra ha terminado; el almuerzo ha comenzado.","../capitoli/capitulo23/VCover.mp4",[308,309],{"type":16,"src":74,"textOverlay":8,"textEffect":8},{"type":16,"src":76,"textOverlay":8,"textEffect":8},"content:comics:capitolo-23.json","comics/capitolo-23.json","comics/capitolo-23",1771727123736]