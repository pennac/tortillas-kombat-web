[{"_path":"/comics/capitolo-1","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"01: El Vapor de Sartenópolis","description":"En las calles oxidadas de la capital, el vapor oculta la miseria. Un ronin solitario llega a la ciudad buscando algo más que comida sintética.","cover":"../capitoli/capitulo1/VCover.mp4","releaseDate":"2023-01-01","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo1/Vcover.mp4","textOverlay":"En las calles oxidadas de la capital, el vapor oculta la miseria. Un ronin solitario llega a la ciudad buscando algo más que comida sintética.","textEffect":""},{"type":"Video","src":"../capitoli/capitulo1/V01.mp4","textOverlay":"Era del Colesterol, Año 20XX. Sartenópolis: Donde el aceite nunca deja de hervir.","textEffect":""},{"type":"Video","src":"../capitoli/capitulo1/V02.mp4","textOverlay":"PATATAS REGENERADAS - OFERTA! En las calles, los ''impuros'' se arrastran por una gota de salsa.","textEffect":""},{"type":"Video","src":"../capitoli/capitulo1/V03.mp4","textOverlay":"¡LA PUREZA ES ORDEN. EL ORDEN ES SABOR. El Ojo del Tuorlo lo ve todo.","textEffect":""},{"type":"Video","src":"../capitoli/capitulo1/V04.mp4","textOverlay":"La Guardia avanza. Sin preguntas. Sin piedad.","textEffect":"CLANK! CLANK!"},{"type":"Video","src":"../capitoli/capitulo1/V05.mp4","textOverlay":"DOCUMENTACIÓN! ¡AHORA! El miedo tiene sabor metálico.","textEffect":""},{"type":"Video","src":"../capitoli/capitulo1/V06.mp4","textOverlay":"¡GERMINACIÓN ILEGAL DETECTADA! Ser diferente es sentencia de muerte.","textEffect":""},{"type":"Video","src":"../capitoli/capitulo1/V07.mp4","textOverlay":"Pero el vapor oculta secretos. Un guerrero cocinado a fuego lento.","textEffect":""},{"type":"Video","src":"../capitoli/capitulo1/V08.mp4","textOverlay":"Ojos que han visto caer imperios.","textEffect":""},{"type":"Video","src":"../capitoli/capitulo1/V09.mp4","textOverlay":"Una sombra pequeña y rápida rompe el miedo.","textEffect":"¡ZAS!"},{"type":"Video","src":"../capitoli/capitulo1/V10.mp4","textOverlay":"¡LADRONA! ¡DETENGAN A LA ACEITUNA!","textEffect":"WEEE-OOO-WEEE-OOO"},{"type":"Video","src":"../capitoli/capitulo1/V11.mp4","textOverlay":"Se acabó el descanso.","textEffect":"K-CLACK"},{"type":"Video","src":"../capitoli/capitulo1/V12.mp4","textOverlay":"Oye, Huevo... te vas a quemar.","textEffect":""},{"type":"Video","src":"../capitoli/capitulo1/V13.mp4","textOverlay":"El Ronin entra en la cocina.","textEffect":""}],"_id":"content:comics:capitolo-1.json","_type":"json","_source":"content","_file":"comics/capitolo-1.json","_stem":"comics/capitolo-1","_extension":"json"},{"_path":"/comics/capitolo-2","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"02: El Robo de la Aceituna","description":"Una pequeña ladrona corre por los tejados. Cuando la ley del más fuerte está a punto de aplastarla, un cucharón de madera cambia su destino.","cover":"../capitoli/capitulo2/VCover.mp4","releaseDate":"2025-03-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-2.json","_type":"json","_source":"content","_file":"comics/capitolo-2.json","_stem":"comics/capitolo-2","_extension":"json"},{"_path":"/comics/capitolo-3","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"03: El Banquete de los Pobres","description":"Un convoy militar lleno de verduras reales es interceptado. Esa noche, el barrio bajo conoce el verdadero sabor, pero el cielo trae una advertencia digital.","cover":"../capitoli/capitulo3/VCover.mp4","releaseDate":"2026-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-3.json","_type":"json","_source":"content","_file":"comics/capitolo-3.json","_stem":"comics/capitolo-3","_extension":"json"},{"_path":"/comics/capitolo-4","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"04: Cenizas y Recuerdos","description":"Huyendo al desierto blanco, bajo la luz de las estrellas, Patato revela la cicatriz de su pasado: la historia de dos hermanos en la Academia del Vuelco.","cover":"../capitoli/capitulo4/VCover.mp4","releaseDate":"2026-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-4.json","_type":"json","_source":"content","_file":"comics/capitolo-4.json","_stem":"comics/capitolo-4","_extension":"json"},{"_path":"/comics/capitolo-5","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"05: El Fruto Prohibido","description":"En el mercado negro, el Joven Patato prueba lo impensable: la cebolla. Una explosión de sabor que cambiará su vida para siempre.","cover":"../capitoli/capitulo5/VCover.mp4","releaseDate":"2026-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-5.json","_type":"json","_source":"content","_file":"comics/capitolo-5.json","_stem":"comics/capitolo-5","_extension":"json"},{"_path":"/comics/capitolo-6","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"06: La Traición Mecánica","description":"El amanecer trae la acusación. Roto denuncia a su hermano por impureza. Un juicio farsa, un uniforme rasgado y el exilio al desierto.","cover":"../capitoli/capitulo6/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo6/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-6.json","_type":"json","_source":"content","_file":"comics/capitolo-6.json","_stem":"comics/capitolo-6","_extension":"json"},{"_path":"/comics/capitolo-7","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"07: El Santuario de Sal","description":"De vuelta al presente. En las Minas de Sal, Patato debe endurecer su piel para soportar el peso del mundo. La primera lección es la consistencia.","cover":"../capitoli/capitulo7/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-7.json","_type":"json","_source":"content","_file":"comics/capitolo-7.json","_stem":"comics/capitolo-7","_extension":"json"},{"_path":"/comics/capitolo-8","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"08: El Desierto de Pimentón","description":"Un infierno rojo de polvo y calor. El Barón del Chorizo enseña que la mejor defensa es un ataque ardiente. Patato despierta su fuego interior.","cover":"../capitoli/capitulo8/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-8.json","_type":"json","_source":"content","_file":"comics/capitolo-8.json","_stem":"comics/capitolo-8","_extension":"json"},{"_path":"/comics/capitolo-9","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"09: El Bosque Apestoso","description":"Una ciénaga verde y tóxica. La Abuela Ajo demuestra que el verdadero poder es la persistencia: un aroma que nunca se va.","cover":"../capitoli/capitulo9/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-9.json","_type":"json","_source":"content","_file":"comics/capitolo-9.json","_stem":"comics/capitolo-9","_extension":"json"},{"_path":"/comics/capitolo-10","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"10: El Monje del Aceite","description":"En un templo flotante sobre un río negro, la fuerza bruta resbala. Patato debe aprender a fluir y emulsionarse con el enemigo.","cover":"../capitoli/capitulo10/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-10.json","_type":"json","_source":"content","_file":"comics/capitolo-10.json","_stem":"comics/capitolo-10","_extension":"json"},{"_path":"/comics/capitolo-11","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"11: El Laberinto de Pimientos","description":"Una jungla donde la lógica no existe. Los gemelos del azar juegan con la mente de Patato. La lección es la sorpresa: lo dulce y lo picante a la vez.","cover":"../capitoli/capitulo11/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-11.json","_type":"json","_source":"content","_file":"comics/capitolo-11.json","_stem":"comics/capitolo-11","_extension":"json"},{"_path":"/comics/capitolo-12","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"12: El Espíritu del Pan","description":"Entre ruinas antiguas, un gigante de miga enseña que nadie puede sostenerse solo. Aceituna se convierte en el pilar fundamental de Patato.","cover":"../capitoli/capitulo12/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-12.json","_type":"json","_source":"content","_file":"comics/capitolo-12.json","_stem":"comics/capitolo-12","_extension":"json"},{"_path":"/comics/capitolo-13","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"13: Las Alcantarillas de la Resistencia","description":"En el subsuelo, la Matriarca Cebolla espera. Para obtener el último sello, Patato debe llorar y romper su coraza emocional. La Armonía final.","cover":"../capitoli/capitulo13/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-13.json","_type":"json","_source":"content","_file":"comics/capitolo-13.json","_stem":"comics/capitolo-13","_extension":"json"},{"_path":"/comics/capitolo-14","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"14: La Prisión de la Despensa","description":"Infiltración fallida en Sartenópolis. Patato es capturado y congelado. Aceituna y una vieja amiga ninja lanzan un rescate desesperado.","cover":"../capitoli/capitulo14/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-14.json","_type":"json","_source":"content","_file":"comics/capitolo-14.json","_stem":"comics/capitolo-14","_extension":"json"},{"_path":"/comics/capitolo-15","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"15: El Sacrificio del Maestro","description":"En la arena, la burocracia amenaza con descalificar al Ronin. Un viejo maestro entrega su honor y su vida para darle una oportunidad a su alumno.","cover":"../capitoli/capitulo15/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-15.json","_type":"json","_source":"content","_file":"comics/capitolo-15.json","_stem":"comics/capitolo-15","_extension":"json"},{"_path":"/comics/capitolo-16","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"16: La Sartén Vacía","description":"Sin ingredientes, confiscados por el régimen. Patato-Pan está solo. Aceituna le lanza su herencia: una única anchoa que vale por un ejército.","cover":"../capitoli/capitulo5/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-16.json","_type":"json","_source":"content","_file":"comics/capitolo-16.json","_stem":"comics/capitolo-16","_extension":"json"},{"_path":"/comics/capitolo-17","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"17: La Ofrenda del Pueblo - Cuartos de Final","description":"Contra un robot ultra-rápido. El pueblo se rebela lanzando comida a la arena. Patato cocina el caos y vence a la lógica de la máquina.","cover":"../capitoli/capitulo17/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-17.json","_type":"json","_source":"content","_file":"comics/capitolo-17.json","_stem":"comics/capitolo-17","_extension":"json"},{"_path":"/comics/capitolo-18","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"18: La Semifinal Brutal","description":"Contra la fuerza pura. Un culturista de cáscara impenetrable. Patato usa el aceite para hacer caer al gigante por su propio peso.","cover":"../capitoli/capitulo18/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-18.json","_type":"json","_source":"content","_file":"comics/capitolo-18.json","_stem":"comics/capitolo-18","_extension":"json"},{"_path":"/comics/capitolo-19","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"19: Alma contra Máquina (La Gran Final - Parte 1)","description":"Patato-Pan vs Roto. Madera vs Oro. Mientras cocinan y luchan, Roto confiesa su envidia: la técnica nunca pudo superar al talento natural.","cover":"../capitoli/capitulo19/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-19.json","_type":"json","_source":"content","_file":"comics/capitolo-19.json","_stem":"comics/capitolo-19","_extension":"json"},{"_path":"/comics/capitolo-20","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"20: El Juicio del Gusto (La Gran Final - Parte 2)","description":"Los platos se sirven. Roto llora al probar el sabor de la infancia. Frito, furioso por la derrota ideológica, activa su Trono de Guerra.","cover":"../capitoli/capitulo20/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-20.json","_type":"json","_source":"content","_file":"comics/capitolo-20.json","_stem":"comics/capitolo-20","_extension":"json"},{"_path":"/comics/capitolo-21","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"21: El Asedio del Cascarón","description":"El Mecha-Trono destruye la arena. Patato y Roto luchan juntos. Roto sacrifica su espátula de oro para bloquear los engranajes del monstruo.","cover":"../capitoli/capitulo21/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-21.json","_type":"json","_source":"content","_file":"comics/capitolo-21.json","_stem":"comics/capitolo-21","_extension":"json"},{"_path":"/comics/capitolo-22","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"22: La Gran Tortilla","description":"La explosión final. Una onda expansiva de huevo cubre la ciudad. El tirano emerge desnudo y ridículo, derrotado por la risa del pueblo.","cover":"../capitoli/capitulo22/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-22.json","_type":"json","_source":"content","_file":"comics/capitolo-22.json","_stem":"comics/capitolo-22","_extension":"json"},{"_path":"/comics/capitolo-23","_dir":"comics","_draft":false,"_partial":false,"_locale":"","title":"23: El Gran Banquete (Epílogo)","description":"Un año después. Sartenópolis es verde y libre. Una mesa larga reúne a amigos y antiguos enemigos. La guerra ha terminado; el almuerzo ha comenzado.","cover":"../capitoli/capitulo23/VCover.mp4","releaseDate":"2027-04-21","audioTheme":"../audio/TKILTRAILERHYPE.mp3","panels":[{"type":"Video","src":"../capitoli/capitulo2/V01.mp4","textOverlay":"","textEffect":""},{"type":"Video","src":"../capitoli/capitulo2/V02.mp4","textOverlay":"","textEffect":""}],"_id":"content:comics:capitolo-23.json","_type":"json","_source":"content","_file":"comics/capitolo-23.json","_stem":"comics/capitolo-23","_extension":"json"}]